{
    "name": "three_oh_eight/seo",
    "description": "Lean, Laravel-native SEO tag management",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/view": "^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "ThreeOhEight\\Seo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ThreeOhEight\\Seo\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "ThreeOhEight\\Seo\\SeoServiceProvider"
            ],
            "aliases": {
                "Seo": "ThreeOhEight\\Seo\\Facades\\Seo"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
